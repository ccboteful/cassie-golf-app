# App runtime (Next.js)
NEXT_PUBLIC_SANITY_PROJECT_ID=yourProjectId
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2026-03-18

# Seeding (write token from https://www.sanity.io/manage)
SANITY_API_TOKEN=yourWriteToken

# Optional: Studio explicit values (defaults to NEXT_PUBLIC_* values)
SANITY_STUDIO_PROJECT_ID=yourProjectId
SANITY_STUDIO_DATASET=production
